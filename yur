import time
import pygame
import os
import csv

# Iniciliar Pygame y configurar la pantalla
pygame.init()
screen = pygame.display.set_mode((800, 600))
pygame.display.set_caption("Gesture Repetition")

# fuente por defecto, tamaño 36
font = pygame.font.SysFont(None, 36)

# Simulación de cliente con estado
client = type("Client", (), {})()
client.current_phase = "rest"
client.time_remaining = 0.0

gestures = [
    "Thumb up",
    "Extension of index and middle, flexion of the others",
    "Flexion of ring and little finger, extension of the others",
    "Thumb apposing base of little finger",
    "Abduction of all fingers",
    "Fingers flexed together in fist",
    "Pointing index",
    "Adduction of extended fingers",
    "Wrist supination (axis: middle finger)",
    "Wrist pronation (axis: middle finger)",
    "Wrist supination (axis: little finger)",
    "Wrist pronation (axis: little finger)",
    "Wrist flexion",
    "Wrist extension",
    "Wrist radial deviation",
    "Wrist ulnar deviation",
    "Wrist extension with closed hand"
]

def show_gesture(gesture):
    print ("Realiza el gesto: " + gesture)

def draw_frame(screen, font, client, images, g_idx):
    screen.fill((0, 0, 0))
    if client.current_phase == "rest":
        text = font.render("REST", True, (255, 255, 255))
        screen.blit(text, (350, 250))
    else:
        screen.blit(images[g_idx], (200, 100))
        name = font.render(gestures[g_idx], True, (255, 255, 255))
        screen.blit(name, (50, 50))
    countdown = font.render(f"{client.time_remaining:.1f}s", True, (255, 255, 0))
    screen.blit(countdown, (350, 450))
    pygame.display.flip()

def run_phase(duration, phase, screen, font, images, g_idx, client):
    clock = pygame.time.Clock()  # ← create once here
    start = time.time()
    while time.time() - start < duration:
        client.time_remaining = duration - (time.time() - start)
        client.current_phase = phase
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                pygame.quit()
                exit()
        draw_frame(screen, font, client, images, g_idx)
        clock.tick(30)  # ← use the same one
    
def main():
    #abrir el archivo de log para escribir los datos de la sesión
    log_file = open("data/session_log.csv", "w", newline='')
    writer = csv.writer(log_file)
    writer.writerow(["timestamp", "gesture", "rep", "phase"])
    session_start = time.time()

    #Pre-cargar las imágenes de los gestos para evitar retrasos durante la ejecución
    images = []
    for i in range(1, 18):
        img = pygame.image.load(os.path.join("gestures", f"{i}.png"))
        images.append(pygame.transform.scale(img, (400, 400)))

    #Pantalla de bienvenida
    client.current_phase = "rest"
    client.time_remaining = 0.0
    screen.fill((0, 0, 0))
    text = font.render("Bienvenido al protocolo ENPRO", True, (255, 255, 255))
    screen.blit(text, (200, 250))
    pygame.display.flip()
    time.sleep(3.0)
    
    for g_idx, gesture in enumerate(gestures):
        
        for rep in range(6):
            writer.writerow([time.time() - session_start, g_idx + 1, rep + 1, "rest"])
            run_phase(3.0, "rest", screen, font, images, g_idx, client)
            writer.writerow([time.time() - session_start, g_idx + 1, rep + 1, "contraction"])
            run_phase(5.0, "contraction", screen, font, images, g_idx, client)

    log_file.close()


if __name__ == "__main__":
    main()